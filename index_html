<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>BRSA Foundation — Behavioral Readiness Standards Authority</title>
  <meta name="description" content="The BRSA Foundation funds access to behavioral readiness evaluation and certification programs for underserved individuals across housing, workforce, corrections, and education sectors." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    /* ─── TOKENS ─── */
    :root {
      --navy:   #1A3A5C;
      --gold:   #C8A84B;
      --gold-lt:#e0c87a;
      --cream:  #f6f3ee;
      --cream-d:#ece8e0;
      --ink:    #1a1a1a;
      --muted:  #5a6472;
      --border: rgba(200,168,75,0.25);
      --ff-serif: 'Playfair Display', Georgia, serif;
      --ff-sans:  'Inter', system-ui, sans-serif;
      --max-w: 1160px;
      --ease: cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    /* ─── RESET ─── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; font-size: 16px; }
    body {
      font-family: var(--ff-sans);
      background: var(--cream);
      color: var(--ink);
      line-height: 1.6;
      overflow-x: hidden;
    }
    img { display: block; max-width: 100%; }
    a { text-decoration: none; color: inherit; }

    /* ─── UTILITY ─── */
    .container { max-width: var(--max-w); margin: 0 auto; padding: 0 2rem; }
    .gold-rule {
      display: block;
      width: 60px; height: 3px;
      background: var(--gold);
      margin-bottom: 1.5rem;
    }
    .section-label {
      font-family: var(--ff-sans);
      font-size: .7rem;
      font-weight: 600;
      letter-spacing: .2em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: .75rem;
    }
    .btn {
      display: inline-flex;
      align-items: center;
      gap: .5rem;
      font-family: var(--ff-sans);
      font-size: .85rem;
      font-weight: 600;
      letter-spacing: .08em;
      text-transform: uppercase;
      padding: .85rem 2rem;
      border-radius: 2px;
      transition: all .25s var(--ease);
      cursor: pointer;
    }
    .btn-primary {
      background: var(--gold);
      color: var(--navy);
      border: 2px solid var(--gold);
    }
    .btn-primary:hover {
      background: var(--gold-lt);
      border-color: var(--gold-lt);
      transform: translateY(-1px);
      box-shadow: 0 8px 24px rgba(200,168,75,.3);
    }
    .btn-outline {
      background: transparent;
      color: var(--cream);
      border: 2px solid rgba(246,243,238,.4);
    }
    .btn-outline:hover {
      border-color: var(--gold);
      color: var(--gold);
    }

    /* ─── TOPBAR ─── */
    .topbar {
      background: var(--navy);
      padding: .5rem 0;
      font-size: .72rem;
      font-weight: 500;
      letter-spacing: .08em;
      color: rgba(246,243,238,.6);
    }
    .topbar .container {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .topbar a { color: var(--gold); transition: opacity .2s; }
    .topbar a:hover { opacity: .75; }

    /* ─── NAV ─── */
    .nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--navy);
      border-bottom: 1px solid rgba(200,168,75,.2);
    }
    .nav-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 72px;
    }
    .nav-brand {
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .nav-seal {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      background: var(--gold);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      overflow: hidden;
    }
    .nav-seal img { width: 44px; height: 44px; object-fit: cover; border-radius: 50%; }
    /* Fallback seal if no logo PNG yet */
    .seal-fallback {
      width: 44px; height: 44px;
      border-radius: 50%;
      background: var(--navy);
      border: 2px solid var(--gold);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--ff-serif);
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--gold);
    }
    .nav-wordmark {
      display: flex;
      flex-direction: column;
      line-height: 1.1;
    }
    .nav-wordmark strong {
      font-family: var(--ff-serif);
      font-size: 1rem;
      font-weight: 600;
      color: var(--cream);
      letter-spacing: .04em;
    }
    .nav-wordmark span {
      font-size: .62rem;
      font-weight: 400;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: var(--gold);
    }
    .nav-links {
      display: flex;
      align-items: center;
      gap: 2.5rem;
      list-style: none;
    }
    .nav-links a {
      font-size: .8rem;
      font-weight: 500;
      letter-spacing: .06em;
      text-transform: uppercase;
      color: rgba(246,243,238,.75);
      transition: color .2s;
    }
    .nav-links a:hover { color: var(--gold); }
    .nav-cta {
      font-size: .75rem !important;
      color: var(--gold) !important;
      border: 1px solid var(--gold) !important;
      padding: .4rem 1rem;
      border-radius: 2px;
    }
    .nav-cta:hover { background: var(--gold) !important; color: var(--navy) !important; }

    /* ─── HERO ─── */
    .hero {
      background: var(--navy);
      position: relative;
      overflow: hidden;
      padding: 7rem 0 6rem;
    }
    /* Subtle background texture */
    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 80% 60% at 70% 50%, rgba(200,168,75,.07) 0%, transparent 70%),
        radial-gradient(ellipse 50% 80% at 10% 80%, rgba(200,168,75,.05) 0%, transparent 60%);
      pointer-events: none;
    }
    /* Decorative corner rule */
    .hero::after {
      content: '';
      position: absolute;
      top: 3rem; right: 3rem;
      width: 120px; height: 120px;
      border-top: 1px solid rgba(200,168,75,.2);
      border-right: 1px solid rgba(200,168,75,.2);
      pointer-events: none;
    }
    .hero-inner {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 4rem;
      align-items: center;
      position: relative;
    }
    .hero-eyebrow {
      font-size: .7rem;
      font-weight: 600;
      letter-spacing: .25em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .hero-eyebrow::before {
      content: '';
      display: block;
      width: 40px;
      height: 1px;
      background: var(--gold);
    }
    .hero h1 {
      font-family: var(--ff-serif);
      font-size: clamp(2.4rem, 5vw, 3.8rem);
      font-weight: 400;
      line-height: 1.15;
      color: var(--cream);
      margin-bottom: 1.75rem;
    }
    .hero h1 em {
      font-style: italic;
      color: var(--gold);
    }
    .hero-sub {
      font-size: 1.05rem;
      font-weight: 300;
      line-height: 1.75;
      color: rgba(246,243,238,.72);
      max-width: 520px;
      margin-bottom: 2.75rem;
    }
    .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
    .hero-seal {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      opacity: .9;
    }
    .hero-seal-img {
      width: 160px;
      height: 160px;
      border-radius: 50%;
      background: rgba(200,168,75,.12);
      border: 1px solid rgba(200,168,75,.3);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .hero-seal-img img { width: 100%; height: 100%; object-fit: cover; }
    /* Fallback large seal */
    .hero-seal-placeholder {
      width: 160px; height: 160px;
      border-radius: 50%;
      background: rgba(200,168,75,.08);
      border: 2px solid rgba(200,168,75,.35);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: .25rem;
    }
    .hero-seal-placeholder .mono {
      font-family: var(--ff-serif);
      font-size: 3rem;
      font-weight: 700;
      color: var(--gold);
      line-height: 1;
    }
    .hero-seal-placeholder .est {
      font-size: .55rem;
      letter-spacing: .2em;
      text-transform: uppercase;
      color: rgba(200,168,75,.7);
    }
    .hero-stat {
      text-align: center;
    }
    .hero-stat .num {
      font-family: var(--ff-serif);
      font-size: 1.4rem;
      font-weight: 600;
      color: var(--gold);
    }
    .hero-stat .lbl {
      font-size: .65rem;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: rgba(246,243,238,.5);
    }

    /* ─── DIVIDER ─── */
    .gold-band {
      background: var(--gold);
      padding: .8rem 0;
      overflow: hidden;
    }
    .gold-band-inner {
      display: flex;
      gap: 3rem;
      white-space: nowrap;
      animation: ticker 30s linear infinite;
    }
    .gold-band-inner span {
      font-size: .7rem;
      font-weight: 600;
      letter-spacing: .2em;
      text-transform: uppercase;
      color: var(--navy);
      flex-shrink: 0;
    }
    .gold-band-inner span::before {
      content: '◆';
      margin-right: 1.5rem;
      opacity: .5;
    }
    @keyframes ticker {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }

    /* ─── MISSION ─── */
    .mission { padding: 6rem 0; background: var(--cream); }
    .mission-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: start;
    }
    .mission h2 {
      font-family: var(--ff-serif);
      font-size: clamp(2rem, 3.5vw, 2.8rem);
      font-weight: 400;
      line-height: 1.25;
      color: var(--navy);
      margin-bottom: 1.5rem;
    }
    .mission p {
      font-size: 1rem;
      line-height: 1.8;
      color: var(--muted);
      margin-bottom: 1.25rem;
    }
    .mission-right { padding-top: 3.5rem; }
    .mission-quote {
      border-left: 3px solid var(--gold);
      padding-left: 1.75rem;
      margin-bottom: 2.5rem;
    }
    .mission-quote blockquote {
      font-family: var(--ff-serif);
      font-size: 1.25rem;
      font-style: italic;
      line-height: 1.6;
      color: var(--navy);
      margin-bottom: .75rem;
    }
    .mission-quote cite {
      font-size: .75rem;
      font-weight: 600;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--gold);
      font-style: normal;
    }
    .distinctions {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .distinction-item {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      padding: 1rem 1.25rem;
      background: white;
      border: 1px solid var(--cream-d);
      border-radius: 4px;
    }
    .distinction-icon {
      width: 32px; height: 32px;
      border-radius: 50%;
      background: var(--navy);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      color: var(--gold);
      font-size: .75rem;
      font-weight: 700;
    }
    .distinction-item h4 {
      font-size: .85rem;
      font-weight: 600;
      color: var(--navy);
      margin-bottom: .2rem;
    }
    .distinction-item p {
      font-size: .82rem;
      color: var(--muted);
      line-height: 1.5;
      margin: 0;
    }

    /* ─── FOCUS AREAS ─── */
    .focus { padding: 6rem 0; background: var(--navy); }
    .focus-header { text-align: center; margin-bottom: 3.5rem; }
    .focus-header .section-label { justify-content: center; display: flex; }
    .focus-header h2 {
      font-family: var(--ff-serif);
      font-size: clamp(1.8rem, 3vw, 2.6rem);
      font-weight: 400;
      color: var(--cream);
      margin-bottom: 1rem;
    }
    .focus-header p {
      font-size: .95rem;
      color: rgba(246,243,238,.6);
      max-width: 520px;
      margin: 0 auto;
      line-height: 1.7;
    }
    .focus-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5px;
      background: rgba(200,168,75,.1);
    }
    .focus-card {
      background: rgba(255,255,255,.04);
      padding: 2.5rem 2rem;
      transition: background .25s;
      position: relative;
      overflow: hidden;
    }
    .focus-card::before {
      content: '';
      position: absolute;
      bottom: 0; left: 0;
      width: 100%; height: 2px;
      background: var(--gold);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform .3s var(--ease);
    }
    .focus-card:hover { background: rgba(255,255,255,.07); }
    .focus-card:hover::before { transform: scaleX(1); }
    .focus-num {
      font-family: var(--ff-serif);
      font-size: 2.5rem;
      font-weight: 700;
      color: rgba(200,168,75,.2);
      line-height: 1;
      margin-bottom: 1.25rem;
    }
    .focus-card h3 {
      font-family: var(--ff-serif);
      font-size: 1.15rem;
      font-weight: 600;
      color: var(--cream);
      margin-bottom: .75rem;
    }
    .focus-card p {
      font-size: .85rem;
      color: rgba(246,243,238,.55);
      line-height: 1.7;
    }
    .focus-tag {
      display: inline-block;
      margin-top: 1rem;
      font-size: .65rem;
      font-weight: 600;
      letter-spacing: .15em;
      text-transform: uppercase;
      color: var(--gold);
      border: 1px solid rgba(200,168,75,.3);
      padding: .2rem .65rem;
      border-radius: 2px;
    }

    /* ─── HOW IT WORKS ─── */
    .how { padding: 6rem 0; background: white; }
    .how-header { margin-bottom: 4rem; }
    .how-header h2 {
      font-family: var(--ff-serif);
      font-size: clamp(1.8rem, 3vw, 2.6rem);
      font-weight: 400;
      color: var(--navy);
    }
    .steps {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 0;
      position: relative;
    }
    .steps::before {
      content: '';
      position: absolute;
      top: 28px; left: 56px; right: 56px;
      height: 1px;
      background: linear-gradient(90deg, var(--gold) 0%, rgba(200,168,75,.2) 100%);
    }
    .step { padding: 0 1.5rem 0 0; position: relative; }
    .step-num {
      width: 56px; height: 56px;
      border-radius: 50%;
      background: var(--navy);
      border: 2px solid var(--gold);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--ff-serif);
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--gold);
      margin-bottom: 1.5rem;
      position: relative;
      z-index: 1;
    }
    .step h4 {
      font-family: var(--ff-serif);
      font-size: 1.05rem;
      font-weight: 600;
      color: var(--navy);
      margin-bottom: .5rem;
    }
    .step p {
      font-size: .85rem;
      color: var(--muted);
      line-height: 1.7;
    }

    /* ─── PARTNERS / CTA ─── */
    .partners { padding: 5rem 0; background: var(--cream-d); }
    .partners-header { text-align: center; margin-bottom: 3rem; }
    .partners-header h2 {
      font-family: var(--ff-serif);
      font-size: 2rem;
      font-weight: 400;
      color: var(--navy);
    }
    .partners-header p {
      font-size: .95rem;
      color: var(--muted);
      margin-top: .75rem;
      max-width: 500px;
      margin-inline: auto;
    }
    .partner-types {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
      margin-bottom: 3rem;
    }
    .partner-type {
      background: white;
      border: 1px solid var(--cream-d);
      border-radius: 4px;
      padding: 2rem;
      text-align: center;
    }
    .partner-type .icon {
      font-size: 1.75rem;
      margin-bottom: 1rem;
    }
    .partner-type h4 {
      font-family: var(--ff-serif);
      font-size: 1rem;
      color: var(--navy);
      margin-bottom: .5rem;
    }
    .partner-type p {
      font-size: .82rem;
      color: var(--muted);
      line-height: 1.6;
    }
    .partners-cta { text-align: center; }

    /* ─── CONTACT / CTA BAND ─── */
    .cta-band {
      background: var(--navy);
      padding: 5rem 0;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .cta-band::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 70% 100% at 50% 100%, rgba(200,168,75,.08), transparent 60%);
      pointer-events: none;
    }
    .cta-band h2 {
      font-family: var(--ff-serif);
      font-size: clamp(1.8rem, 3.5vw, 2.8rem);
      font-weight: 400;
      color: var(--cream);
      margin-bottom: 1rem;
      position: relative;
    }
    .cta-band p {
      font-size: 1rem;
      color: rgba(246,243,238,.65);
      max-width: 480px;
      margin: 0 auto 2.5rem;
      line-height: 1.7;
      position: relative;
    }
    .cta-actions {
      display: flex;
      justify-content: center;
      gap: 1rem;
      flex-wrap: wrap;
      position: relative;
    }
    .btn-gold { background: var(--gold); color: var(--navy); border: 2px solid var(--gold); }
    .btn-gold:hover { background: var(--gold-lt); border-color: var(--gold-lt); transform: translateY(-2px); box-shadow: 0 10px 30px rgba(200,168,75,.3); }
    .btn-navy-outline { background: transparent; color: var(--cream); border: 2px solid rgba(246,243,238,.3); }
    .btn-navy-outline:hover { border-color: var(--gold); color: var(--gold); }

    /* ─── FOOTER ─── */
    .footer { background: #0f2438; padding: 4rem 0 2rem; }
    .footer-inner {
      display: grid;
      grid-template-columns: 1.5fr 1fr 1fr 1fr;
      gap: 3rem;
      padding-bottom: 3rem;
      border-bottom: 1px solid rgba(200,168,75,.12);
    }
    .footer-brand .brand-block {
      display: flex;
      align-items: center;
      gap: .85rem;
      margin-bottom: 1rem;
    }
    .footer-brand .seal-sm {
      width: 36px; height: 36px;
      border-radius: 50%;
      background: rgba(200,168,75,.1);
      border: 1px solid rgba(200,168,75,.3);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .footer-brand .seal-sm img { width: 36px; height: 36px; object-fit: cover; border-radius: 50%; }
    .footer-brand .seal-sm-fallback {
      font-family: var(--ff-serif);
      font-size: .9rem;
      font-weight: 700;
      color: var(--gold);
    }
    .footer-brand strong {
      font-family: var(--ff-serif);
      font-size: .9rem;
      color: var(--cream);
    }
    .footer-brand p {
      font-size: .8rem;
      color: rgba(246,243,238,.45);
      line-height: 1.7;
      margin-bottom: 1rem;
    }
    .footer-status {
      display: inline-flex;
      align-items: center;
      gap: .4rem;
      font-size: .65rem;
      font-weight: 600;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--gold);
      border: 1px solid rgba(200,168,75,.25);
      padding: .25rem .6rem;
      border-radius: 2px;
    }
    .footer-status::before {
      content: '';
      width: 5px; height: 5px;
      border-radius: 50%;
      background: var(--gold);
    }
    .footer-col h5 {
      font-size: .7rem;
      font-weight: 700;
      letter-spacing: .15em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: 1rem;
    }
    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: .6rem; }
    .footer-col ul li a {
      font-size: .82rem;
      color: rgba(246,243,238,.5);
      transition: color .2s;
    }
    .footer-col ul li a:hover { color: var(--cream); }
    .footer-bottom {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding-top: 1.5rem;
      font-size: .72rem;
      color: rgba(246,243,238,.3);
    }
    .footer-bottom a { color: rgba(246,243,238,.45); transition: color .2s; }
    .footer-bottom a:hover { color: var(--gold); }

    /* ─── ANIMATIONS ─── */
    .fade-up {
      opacity: 1;
      transform: translateY(0);
      transition: opacity .6s var(--ease), transform .6s var(--ease);
    }
    .fade-up.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 900px) {
      .hero-inner { grid-template-columns: 1fr; }
      .hero-seal { display: none; }
      .mission-inner { grid-template-columns: 1fr; gap: 3rem; }
      .mission-right { padding-top: 0; }
      .focus-grid { grid-template-columns: 1fr 1fr; }
      .steps { grid-template-columns: 1fr 1fr; gap: 2rem; }
      .steps::before { display: none; }
      .partner-types { grid-template-columns: 1fr; }
